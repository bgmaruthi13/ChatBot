# Copy this file to .env and fill in values as needed.
# Every value below has a safe default if left unset - the app runs
# fully (including chat, via the extractive fallback) with no keys set.

SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- LLM provider (Epic 9) ---
# Leave unset to use the built-in extractive answer mode (no API key
# required). Set to "claude", "openai", "ollama", or "smollm" to enable
# real generation once the matching key/service below is available.
LLM_PROVIDER=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# smollm: runs entirely in-process via transformers - no Ollama, no
# separate server, no API key. Downloads the model to the local HF
# cache on first use (default ~270MB), then fully offline after that.
SMOLLM_MODEL=
